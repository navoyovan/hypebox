---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Starfield from "../components/Starfield.jsx";
import AutoScrollGrid from "../components/AutoScrollGrid.jsx";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import dashImage from "../assets/dash.png";

const starfieldFiles = import.meta.glob<{ default: ImageMetadata }>(
	"/src/assets/starfield/*.webp",
	{ eager: true },
);
const starfieldUrls = Object.values(starfieldFiles).map(
	(file) => file.default.src,
);

// Toggle this to true to enable the intro animation and hide scrollbar
// const ENABLE_INTRO_ANIMATION = false;
const ENABLE_INTRO_ANIMATION = true;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href="data:;base64,=" />
		<title>Hype-booth — The Next-Gen Photobooth</title>
		<script is:inline define:vars={{ ENABLE_INTRO_ANIMATION }}>
			// Prevent browser from restoring scroll position on reload
			if ("scrollRestoration" in history) {
				history.scrollRestoration = ENABLE_INTRO_ANIMATION
					? "manual"
					: "auto";
			}
			if (ENABLE_INTRO_ANIMATION) {
				window.scrollTo(0, 0);
			}
		</script>
		<script>
			// Randomize accent color
			const accents = [
				"#ff6b00", // Vivid Orange (Default)
				"#0055ff", // Electric Blue
				"#ff0066", // Hot Pink
				"#00e676", // Neon Green
				"#8a2be2", // Purple
				"#ffcc00", // Cyber Yellow
			];
			const randomAccent =
				accents[Math.floor(Math.random() * accents.length)];
			document.documentElement.style.setProperty(
				"--color-accent-500",
				randomAccent,
			);
		</script>
	</head>
	<body
		data-intro-enabled={ENABLE_INTRO_ANIMATION}
		class:list={[
			"bg-milky-white text-charcoal-black min-h-screen [overflow-x:clip] w-full relative",
			{ "overflow-hidden": ENABLE_INTRO_ANIMATION },
		]}
	>
		<div class="flex flex-col w-full [overflow-x:clip] relative">
			<Navbar />

			<!-- 0. Starfield Section -->
			<section
				class="w-full h-[85vh] relative overflow-hidden bg-milky-white pt-20 flex items-center justify-center"
			>
				<div class="absolute inset-0 z-0 scale-105 blur-sm opacity-50">
					<!-- Static HTML Fallback (Visible instantly while React downloads on 3G) -->
					<div
						id="starfield-fallback"
						class="absolute inset-0 w-full h-full pointer-events-none transition-opacity duration-1000"
					>
						<!-- Scattered static skeleton frames -->
						<div
							class="absolute top-[15%] left-[10%] w-[15vw] h-[20vw] border-2 border-black/10 bg-black/5 transform -rotate-6"
						>
						</div>
						<div
							class="absolute top-[50%] left-[15%] w-[20vw] h-[25vw] border-2 border-black/10 bg-black/5 transform rotate-3"
						>
						</div>
						<div
							class="absolute top-[20%] right-[10%] w-[18vw] h-[24vw] border-2 border-black/10 bg-black/5 transform rotate-6"
						>
						</div>
						<div
							class="absolute top-[60%] right-[15%] w-[12vw] h-[16vw] border-2 border-black/10 bg-black/5 transform -rotate-12"
						>
						</div>
						<div
							class="absolute top-[35%] left-[40%] w-[25vw] h-[33vw] border-2 border-black/10 bg-black/5 transform -rotate-2"
						>
						</div>
					</div>

					<Starfield client:load urls={starfieldUrls} />
				</div>

				<!-- Bottom Blend Gradient -->
				<div
					class="absolute bottom-0 left-0 w-full h-[30vh] bg-gradient-to-t from-milky-white to-transparent z-10 pointer-events-none"
				>
				</div>

				<!-- Hero Text -->
				<div
					id="hero-title-wrapper"
					class="relative z-10 flex flex-col items-center justify-center pointer-events-none w-full h-[150px]"
				>
					<a
						id="hero-title"
						href="#"
						onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;"
						class="flex flex-col items-center justify-center pointer-events-auto"
					>
						<h1
							id="hero-h1"
							class:list={[
								"font-display font-black text-[clamp(2rem,10vw,8rem)] tracking-tight uppercase text-charcoal-black m-0 leading-none inline-block whitespace-nowrap",
