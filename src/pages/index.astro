			</a>
		)
	}

	<script>
		document.addEventListener("DOMContentLoaded", () => {
			const isIntroEnabled =
				document.body.dataset.introEnabled === "true";
			if (!isIntroEnabled) return;

			const heroTitle = document.getElementById("hero-title");
			const navLogo = document.getElementById("navbar-logo");
			const wrapper = document.getElementById("hero-title-wrapper");

			if (!heroTitle || !navLogo || !wrapper) return;

			let absoluteTop = 0;
			let absoluteLeft = 0;
			let isScrolled = false;
			let transitionTimeout: ReturnType<typeof setTimeout>;
			let targetTransform = "";

			const calculateRects = () => {
				// Move back to wrapper temporarily to calculate native flow rect
				if (heroTitle.parentNode !== wrapper) {
					wrapper.appendChild(heroTitle);
				}

				heroTitle.style.position = "relative";
				heroTitle.style.top = "auto";
				heroTitle.style.left = "auto";
				heroTitle.style.transform = "none";

				const wRect = wrapper.getBoundingClientRect();
				absoluteTop = wRect.top + window.scrollY;
				absoluteLeft = wRect.left + window.scrollX;

				// Lock to fixed
				heroTitle.style.position = "fixed";
				heroTitle.style.top = absoluteTop + "px";
				heroTitle.style.left = absoluteLeft + "px";
				heroTitle.style.width = wRect.width + "px";
				heroTitle.style.height = wRect.height + "px";
				heroTitle.style.transformOrigin = "center center";
				heroTitle.style.zIndex = "60"; // above navbar (z-50)

				// Precalculate the target transform to avoid scroll jitter
				const nRect = navLogo.getBoundingClientRect();
				const h1Elem = document.getElementById("hero-h1");
				const h1Width = h1Elem
					? h1Elem.offsetWidth
					: wrapper.offsetWidth;
				const scale = nRect.width / h1Width;

				const navCenterX = nRect.left + nRect.width / 2;
				const navCenterY = nRect.top + nRect.height / 2;
				const wrapCenterX = absoluteLeft + wrapper.offsetWidth / 2;
				const wrapCenterY = absoluteTop + wrapper.offsetHeight / 2;

				const translateX = navCenterX - wrapCenterX;
				const translateY = navCenterY - wrapCenterY;

				targetTransform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;

				// Move to body to escape overflow-hidden clipping from the parent section
				document.body.appendChild(heroTitle);

				// If we are already scrolled, immediately apply the new precalculated target
				if (isScrolled) {
					heroTitle.style.transition = "none";
					heroTitle.style.transform = targetTransform;
				}

				handleScroll();
			};

			let isAnimationFinished = false;

			// Defer all fixed positioning and reparenting until the initial CSS animation is completely finished!
			// This prevents the browser from restarting the CSS animation when the DOM element is moved.
			setTimeout(() => {
				const h1 = document.getElementById("hero-h1");
				if (h1) h1.classList.remove("animate-title-entrance");

				isAnimationFinished = true;
				calculateRects();
			}, 2000);

			// Cinematic Intro Sequence (Decoupled from React to ensure it plays immediately on slow networks)
			setTimeout(() => {
				const topBar = document.getElementById("cinematic-top-bar");
				const bottomBar = document.getElementById(
					"cinematic-bottom-bar",
				);
				if (topBar) topBar.classList.add("animate-cinematic-top");
				if (bottomBar)
					bottomBar.classList.add("animate-cinematic-bottom");

				// Unlock scrolling once the 1200ms cinematic bar animation finishes
				setTimeout(() => {
					document.body.classList.remove("overflow-hidden");
				}, 1200);
			}, 2000);

			let lastWidth = window.innerWidth;
			window.addEventListener("resize", () => {
				// Ignore minor width changes (like scrollbar toggles on mobile)
				if (Math.abs(window.innerWidth - lastWidth) > 30) {
					lastWidth = window.innerWidth;
					if (isAnimationFinished) calculateRects();
				}
			});

			const handleScroll = () => {
				if (!isAnimationFinished) return;

				const scrollY = window.scrollY;

				if (scrollY > 100) {
					if (!isScrolled) {
						isScrolled = true;
						clearTimeout(transitionTimeout);
						heroTitle.style.transition =
							"transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94)";
					}

					// Use precalculated constant target to prevent animation jitter on URL bar resize
					heroTitle.style.transform = targetTransform;
				} else {
					if (isScrolled) {
						isScrolled = false;
						heroTitle.style.transition = "transform 0.3s ease-out";

						transitionTimeout = setTimeout(() => {
							if (!isScrolled) {
								heroTitle.style.transition = "none";
							}
						}, 300);
					}
					// Counteract scroll to appear fixed to page flow
					heroTitle.style.transform = `translate(0px, -${scrollY}px) scale(1)`;
				}
			};

			window.addEventListener("scroll", handleScroll, {
				passive: true,
			});
		});
	</script>
