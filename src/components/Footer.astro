---
const currentYear = new Date().getFullYear();
---

<footer class="w-full px-6 md:px-12 lg:px-24 py-12 border-t border-border-subtle bg-bg-primary mt-auto">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    <!-- Copyright -->
    <div class="font-mono text-[10px] uppercase tracking-widest text-text-secondary">
      &copy; {currentYear} Yovan. Crafted for Performance.
    </div>

    <!-- Social / External Links -->
    <div class="flex items-center gap-8 font-mono text-[10px] uppercase tracking-widest">
      <a 
        href="https://github.com" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="text-text-secondary hover:text-text-primary transition-colors duration-250 ease-hover"
      >
        GitHub
      </a>
      <a 
        href="https://linkedin.com" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="text-text-secondary hover:text-text-primary transition-colors duration-250 ease-hover"
      >
        LinkedIn
      </a>
      <a 
        href="https://read.cv" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="text-text-secondary hover:text-text-primary transition-colors duration-250 ease-hover"
      >
        Read.cv
      </a>
    </div>
  </div>
</footer>
