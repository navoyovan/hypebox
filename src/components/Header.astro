---
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 w-full z-50 px-6 md:px-12 lg:px-24 py-6 border-b border-border-subtle bg-bg-primary/80 backdrop-blur-md">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo/Initials -->
    <a 
      href="/" 
      class="font-display font-light text-2xl tracking-tighter hover:opacity-80 transition-opacity"
    >
      yovan<span class="text-text-secondary">.</span>
    </a>

    <!-- Navigation links -->
    <nav class="flex items-center gap-8 md:gap-12">
      <a 
        href="/" 
        class={`font-mono text-xs uppercase tracking-widest transition-colors duration-250 ease-hover ${
          currentPath === "/" ? "text-text-primary" : "text-text-secondary hover:text-text-primary"
        }`}
      >
        Work
      </a>
      <a 
        href="/about" 
        class={`font-mono text-xs uppercase tracking-widest transition-colors duration-250 ease-hover ${
          currentPath === "/about" || currentPath === "/about/" ? "text-text-primary" : "text-text-secondary hover:text-text-primary"
        }`}
      >
        About
      </a>
      <a 
        href="mailto:hello@yovan.dev" 
        class="font-mono text-xs uppercase tracking-widest text-text-secondary hover:text-text-primary transition-colors duration-250 ease-hover"
      >
        Contact
      </a>
    </nav>
  </div>
</header>
